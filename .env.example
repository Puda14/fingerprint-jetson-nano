# ===========================================================================
# Fingerprint Jetson Nano Worker — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in real values before running.
# All variables use the WORKER_ prefix.

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------
WORKER_HOST=0.0.0.0
WORKER_PORT=8000
WORKER_DEBUG=false

# ---------------------------------------------------------------------------
# Device Identification
# ---------------------------------------------------------------------------
WORKER_DEVICE_ID=JETSON-001

# ---------------------------------------------------------------------------
# Inference Backend
# Choose "tensorrt" for optimized speed on Jetson Nano (FP16).
# Choose "onnx" to run on PC / CPU without TensorRT.
# ---------------------------------------------------------------------------
WORKER_BACKEND=tensorrt
WORKER_MODEL_PATH=models/mdgtv2_fp16.engine
WORKER_MODEL_DIR=models/
WORKER_DATA_DIR=data/
WORKER_BACKUP_DIR=data/backups/

# ---------------------------------------------------------------------------
# Pipeline Parameters
# ---------------------------------------------------------------------------
WORKER_IMAGE_WIDTH=192
WORKER_IMAGE_HEIGHT=192
WORKER_KNN_K=16
WORKER_EMBEDDING_DIM=256
WORKER_EXTRACTOR=cn
WORKER_FINGERNET_MODEL_PATH=
WORKER_CLAHE_CLIP=2.5
WORKER_CLAHE_GRID=8

# ---------------------------------------------------------------------------
# Matching Thresholds
# ---------------------------------------------------------------------------
WORKER_VERIFY_THRESHOLD=0.55
WORKER_IDENTIFY_THRESHOLD=0.50
WORKER_IDENTIFY_TOP_K=5

# ---------------------------------------------------------------------------
# Fingerprint Sensor (USB)
# ---------------------------------------------------------------------------
WORKER_SENSOR_VID=0x0483
WORKER_SENSOR_PID=0x5720
WORKER_SENSOR_SDK_PATH=/opt/fingerprint-sdk

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
WORKER_DATABASE_URL=sqlite+aiosqlite:///data/fingerprint.db

# ---------------------------------------------------------------------------
# MQTT — Connection to Orchestrator
# ---------------------------------------------------------------------------
WORKER_MQTT_ENABLED=true
WORKER_MQTT_BROKER_HOST=<orchestrator-ip>
WORKER_MQTT_BROKER_PORT=1883
WORKER_MQTT_USERNAME=
WORKER_MQTT_PASSWORD=
WORKER_MQTT_CLIENT_ID=
WORKER_MQTT_KEEPALIVE=60
WORKER_MQTT_RECONNECT_DELAY=5
WORKER_HEARTBEAT_INTERVAL=10

# ---------------------------------------------------------------------------
# Encryption — Fernet key for encrypting fingerprint embeddings at rest
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# If empty, a key will be auto-generated and saved to data/.fingerprint_key
# ---------------------------------------------------------------------------
WORKER_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# CORS — allowed origins to access API
# ---------------------------------------------------------------------------
WORKER_CORS_ORIGINS='["http://localhost:3000","http://localhost:5173","http://localhost:8080"]'
